# VIP Report — Streamlit Secrets
# Paste these into: Streamlit Cloud → App → Settings → Secrets
# Or save locally to: ~/.streamlit/secrets.toml

# Mailchimp (static — never expires)
MAILCHIMP_API_KEY = "YOUR_MAILCHIMP_API_KEY-us14"
MAILCHIMP_LIST_ID = "YOUR_AUDIENCE_ID"

# Constant Contact — run cc_get_refresh_token.py once to get this
# Lasts 60 days of non-use (auto-resets with each weekly run)
CC_REFRESH_TOKEN = "PASTE_YOUR_REFRESH_TOKEN_HERE"
